@page "/register"
@rendermode InteractiveServer
@using BlazorFormApp.Models

<div class="page-wrapper">
    <div class="form-card">

        <h3>User Registration</h3>
        <p class="form-sub">Fields marked <span>*</span> are required.</p>

        <EditForm Model="@model" OnValidSubmit="HandleValidSubmit">

            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="name-row">
                <div class="fg">
                    <label>First name <span class="req">*</span></label>
                    <InputText @bind-Value="model.FirstName" />
                    <ValidationMessage For="@(() => model.FirstName)" />
                </div>
                <div class="fg">
                    <label>Last name <span class="req">*</span></label>
                    <InputText @bind-Value="model.LastName" />
                    <ValidationMessage For="@(() => model.LastName)" />
                </div>
            </div>

            <div class="fg">
                <label>Email address <span class="req">*</span></label>
                <InputText @bind-Value="model.Email" type="email" />
                <ValidationMessage For="@(() => model.Email)" />
            </div>

            <button type="submit" class="submit-btn">Submit Registration</button>

        </EditForm>

        @if (isSubmitted)
        {
            <div class="success-box">
                <div class="success-icon">✔</div>
                <div class="success-title">Registration Successful!</div>
                <div class="success-detail">
                    Welcome, @model.FirstName! A confirmation has been sent to @model.Email.
                </div>
            </div>
        }

    </div>
</div>

@code {
    private UserModel model = new();
    private bool isSubmitted = false;

    private void HandleValidSubmit()
    {
        isSubmitted = true;
    }
}